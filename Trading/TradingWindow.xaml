<Window x:Class="Trading.TradingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TradingWindow" Height="700" Width="1100"
        Background="#1A2233" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Grid.Column="0" Background="#232B3E" VerticalAlignment="Stretch">
            <TextBlock Text="TradePro" Foreground="#4FC3F7" FontSize="28" FontWeight="Bold" Margin="20,30,0,40"/>
            <Button Content="Dashboard" Margin="10,0,10,10" Foreground="White" Background="#2C3654" Height="40"/>
            <Button Content="Orders" Margin="10,0,10,10" Foreground="White" Background="#2C3654" Height="40"/>
            <Button Content="History" Margin="10,0,10,10" Foreground="White" Background="#2C3654" Height="40"/>
            <Button Content="Settings" Margin="10,0,10,10" Foreground="White" Background="#2C3654" Height="40"/>
            <StackPanel VerticalAlignment="Bottom" Margin="10,40,10,20">
                <TextBlock Text="User: trader01" Foreground="#B0BEC5" FontSize="14" Margin="0,0,0,5"/>
                <TextBlock Text="Status: Online" Foreground="#81C784" FontSize="12"/>
            </StackPanel>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Text="Trading Dashboard" FontSize="32" FontWeight="Bold" Foreground="#4FC3F7" Margin="30,30,0,10"/>

            <!-- Account Summary -->
            <Border Grid.Row="1" Margin="30,0,30,20" Padding="18" Background="#232B3E" CornerRadius="10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <StackPanel Margin="0,0,40,0">
                        <TextBlock Text="Account Balance" FontWeight="Bold" Foreground="#B0BEC5"/>
                        <TextBlock Text="$100,000" FontSize="20" Foreground="#4FC3F7" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,40,0">
                        <TextBlock Text="Open P/L" FontWeight="Bold" Foreground="#B0BEC5"/>
                        <TextBlock Text="$1,250" FontSize="20" Foreground="#81C784" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Margin Used" FontWeight="Bold" Foreground="#B0BEC5"/>
                        <TextBlock Text="$10,000" FontSize="20" Foreground="#FFD54F" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Main Trading Area -->
            <Grid Grid.Row="2" Margin="30,0,30,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- Order Entry Panel -->
                <Border Padding="20" Background="#26304A" CornerRadius="10" Margin="0,0,30,0">
                    <StackPanel>
                        <TextBlock Text="Order Entry" FontSize="20" FontWeight="Bold" Foreground="#4FC3F7" Margin="0,0,0,18"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Symbol:" Width="70" VerticalAlignment="Center" Foreground="#B0BEC5"/>
                            <TextBox Width="120" x:Name="SymbolTextBox" Background="#232B3E" Foreground="White" BorderBrush="#4FC3F7"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Quantity:" Width="70" VerticalAlignment="Center" Foreground="#B0BEC5"/>
                            <TextBox Width="120" x:Name="QuantityTextBox" Background="#232B3E" Foreground="White" BorderBrush="#4FC3F7"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Price:" Width="70" VerticalAlignment="Center" Foreground="#B0BEC5"/>
                            <TextBox Width="120" x:Name="PriceTextBox" Background="#232B3E" Foreground="White" BorderBrush="#4FC3F7"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <RadioButton Content="Buy" GroupName="Side" x:Name="BuyRadioButton" IsChecked="True" Foreground="#81C784" FontWeight="Bold" Margin="0,0,20,0"/>
                            <RadioButton Content="Sell" GroupName="Side" x:Name="SellRadioButton" Foreground="#E57373" FontWeight="Bold"/>
                        </StackPanel>
                        <Button Content="Submit Order" Width="140" Height="38" Background="#4FC3F7" Foreground="#232B3E" FontWeight="Bold" x:Name="SubmitOrderButton"/>
                    </StackPanel>
                </Border>

                <!-- Orders and Trades -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Open Orders" FontSize="18" FontWeight="Bold" Foreground="#B0BEC5" Margin="0,0,0,8"/>
                    <DataGrid x:Name="OpenOrdersGrid" Height="160" AutoGenerateColumns="True" Margin="0,0,0,18"
                              Background="#232B3E" Foreground="White" BorderBrush="#4FC3F7"
                              RowBackground="#26304A" AlternatingRowBackground="#232B3E">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#26304A"/>
                                <Setter Property="Foreground" Value="#4FC3F7"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                    </DataGrid>
                    <TextBlock Text="Trade History" FontSize="18" FontWeight="Bold" Foreground="#B0BEC5" Margin="0,0,0,8"/>
                    <DataGrid x:Name="TradeHistoryGrid" Height="160" AutoGenerateColumns="True"
                              Background="#232B3E" Foreground="White" BorderBrush="#4FC3F7"
                              RowBackground="#26304A" AlternatingRowBackground="#232B3E">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#26304A"/>
                                <Setter Property="Foreground" Value="#4FC3F7"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                    </DataGrid>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
