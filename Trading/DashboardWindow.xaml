<Window x:Class="Trading.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Trading.Converters"
        Title="Trading Dashboard" Height="700" Width="1100"
        Background="#1A2233" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter"/>
        <converters:LessThanZeroConverter x:Key="LessThanZeroConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Grid.Column="0" Background="#232B3E" VerticalAlignment="Stretch">
            <TextBlock Text="TradePro" Foreground="#4FC3F7" FontSize="28" FontWeight="Bold" Margin="20,30,0,40"/>
            <Button Content="Dashboard" Margin="10,0,10,10" Foreground="White" Background="#1976D2" Height="40" FontWeight="Bold"/>
            <Button Content="Trading" Margin="10,0,10,10" Foreground="White" Background="#2C3654" Height="40" Click="OpenTradingWindow_Click"/>
            <Button Content="Orders" Margin="10,0,10,10" Foreground="White" Background="#2C3654" Height="40"/>
            <Button Content="History" Margin="10,0,10,10" Foreground="White" Background="#2C3654" Height="40"/>
            <Button Content="Settings" Margin="10,0,10,10" Foreground="White" Background="#2C3654" Height="40"/>
            <StackPanel VerticalAlignment="Bottom" Margin="10,40,10,20">
                <TextBlock Text="User: trader01" Foreground="#B0BEC5" FontSize="14" Margin="0,0,0,5"/>
                <TextBlock Text="Status: Online" Foreground="#81C784" FontSize="12"/>
            </StackPanel>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="30,30,30,10">
                <TextBlock Text="Dashboard" FontSize="32" FontWeight="Bold" Foreground="#4FC3F7"/>
                <TextBlock Text=" - Market Overview" FontSize="24" Foreground="#B0BEC5" VerticalAlignment="Bottom" Margin="10,0,0,5"/>
            </StackPanel>

            <!-- Summary Cards -->
            <Border Grid.Row="1" Margin="30,0,30,20" Padding="20" Background="#232B3E" CornerRadius="10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Portfolio Summary" FontSize="18" FontWeight="Bold" Foreground="#4FC3F7" Margin="0,0,10,15"/>
                        <TextBlock Text="● Auto-Refreshing" FontSize="12" Foreground="#81C784" VerticalAlignment="Center" Margin="0,0,0,15">
                            <TextBlock.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1.0" To="0.3" Duration="0:0:1" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </TextBlock.Triggers>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <StackPanel Margin="0,0,60,0">
                            <TextBlock Text="Total Symbols" FontWeight="Bold" Foreground="#B0BEC5" FontSize="12"/>
                            <TextBlock Text="{Binding SymbolStats.Count}" FontSize="24" Foreground="#4FC3F7" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,60,0">
                            <TextBlock Text="Active Positions" FontWeight="Bold" Foreground="#B0BEC5" FontSize="12"/>
                            <TextBlock Text="{Binding SymbolStats.Count}" FontSize="24" Foreground="#81C784" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Last Updated" FontWeight="Bold" Foreground="#B0BEC5" FontSize="12"/>
                            <TextBlock Text="{Binding SymbolStats[0].LastUpdated, StringFormat='HH:mm:ss'}" FontSize="16" Foreground="#FFD54F"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Symbol Statistics Grid -->
            <Border Grid.Row="2" Margin="30,0,30,30" Background="#232B3E" CornerRadius="10" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Symbol Performance" FontSize="18" FontWeight="Bold" Foreground="#4FC3F7" Margin="0,0,0,15"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding SymbolStats}" AutoGenerateColumns="False"
                              Background="#26304A" Foreground="White" BorderBrush="#4FC3F7"
                              RowBackground="#26304A" AlternatingRowBackground="#2C3654"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A2233"
                              IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#1976D2"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                <Setter Property="BorderBrush" Value="#1A2233"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="120" FontWeight="Bold" FontSize="14">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#4FC3F7"/>
                                        <Setter Property="Padding" Value="10,5"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Opening Price" Binding="{Binding OpeningPrice, StringFormat=\{0:C2\}}" Width="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="10,5"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Current Price" Binding="{Binding CurrentPrice, StringFormat=\{0:C2\}}" Width="130" FontWeight="Bold">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="10,5"/>
                                        <Setter Property="Foreground" Value="#FFD54F"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Change" Binding="{Binding PriceChangeFormatted}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="10,5"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PriceChange, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                                <Setter Property="Foreground" Value="#81C784"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PriceChange, Converter={StaticResource LessThanZeroConverter}}" Value="True">
                                                <Setter Property="Foreground" Value="#E57373"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Change %" Binding="{Binding PercentageChangeFormatted}" Width="100" FontWeight="Bold">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="10,5"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PercentageChange, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                                <Setter Property="Foreground" Value="#81C784"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PercentageChange, Converter={StaticResource LessThanZeroConverter}}" Value="True">
                                                <Setter Property="Foreground" Value="#E57373"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Total Orders" Binding="{Binding TotalOrders}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="10,5"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Total Quantity" Binding="{Binding TotalQuantity}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="10,5"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
