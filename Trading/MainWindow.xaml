<Window x:Class="Trading.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trading Application" Height="700" Width="1100"
        Background="#1A2233" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Grid.Column="0" Background="#232B3E" VerticalAlignment="Stretch">
            <TextBlock Text="TradePro" Foreground="#4FC3F7" FontSize="28" FontWeight="Bold" Margin="20,30,0,40"/>
            <Button Content="Dashboard" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10,0,10,10" Foreground="White" Background="#2C3654" Height="40"/>
            <Button Content="Orders" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10,0,10,10" Foreground="White" Background="#2C3654" Height="40"/>
            <Button Content="History" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10,0,10,10" Foreground="White" Background="#2C3654" Height="40"/>
            <Button Content="Settings" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="10,0,10,10" Foreground="White" Background="#2C3654" Height="40"/>
            <StackPanel VerticalAlignment="Bottom" Margin="10,40,10,20">
                <TextBlock Text="User: trader01" Foreground="#B0BEC5" FontSize="14" Margin="0,0,0,5"/>
                <TextBlock Text="Status: Online" Foreground="#81C784" FontSize="12"/>
            </StackPanel>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="0,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Text="Trading Dashboard" FontSize="32" FontWeight="Bold" Foreground="#4FC3F7" Margin="30,30,0,10"/>

            <!-- Account Summary -->
            <Border Grid.Row="1" Margin="30,0,30,20" Padding="18" Background="#232B3E" CornerRadius="10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <StackPanel Margin="0,0,40,0">
                        <TextBlock Text="Account Balance" FontWeight="Bold" Foreground="#B0BEC5"/>
                        <TextBlock Text="$100,000" FontSize="20" Foreground="#4FC3F7" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,40,0">
                        <TextBlock Text="Open P/L" FontWeight="Bold" Foreground="#B0BEC5"/>
                        <TextBlock Text="$1,250" FontSize="20" Foreground="#81C784" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Margin Used" FontWeight="Bold" Foreground="#B0BEC5"/>
                        <TextBlock Text="$10,000" FontSize="20" Foreground="#FFD54F" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Row="2" Margin="30,0,30,30">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Welcome to TradePro" FontSize="36" FontWeight="Bold" Foreground="#4FC3F7" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="Your Professional Trading Platform" FontSize="18" Foreground="#B0BEC5" HorizontalAlignment="Center" Margin="0,0,0,40"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Open Dashboard" Width="200" Height="50" Background="#1976D2" Foreground="White" FontWeight="Bold" FontSize="16" Click="OpenDashboard_Click" Margin="0,0,20,0"/>
                        <Button Content="Open Trading Window" Width="200" Height="50" Background="#4FC3F7" Foreground="#232B3E" FontWeight="Bold" FontSize="16" Click="OpenTradingWindow_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
